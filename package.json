{
  "name": "learning-bullmq",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "producer": "bun run src/producer.ts",
    "worker": "bun run src/worker.ts",
    "build": "bun build src/index.ts src/worker.ts --outdir=dist --target=bun --minify",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bullmq": "^5.70.2",
    "elysia": "^1.4.27",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  }
}
