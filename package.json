{
  "name": "learning-bullmq",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "producer": "bun run src/producer.ts",
    "worker": "bun run src/worker.ts",
    "build": "bun build src/index.ts src/worker.ts --outdir=dist --target=bun --minify",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@types/express": "^5.0.6",
    "bullmq": "^5.70.4",
    "express": "^5.2.1",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  }
}
